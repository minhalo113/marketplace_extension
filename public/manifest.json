{
    "manifest_version": 3,
    "name": "My Extension",
    "version": "1.0",
    "description": "My Extension",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://my-website-l1fe.vercel.app/admin/dashboard/edit-product/*",
        "https://my-website-l1fe.vercel.app/admin/dashboard/product-reviews/*",
        "https://www.facebook.com/*",
        "https://www.kijiji.ca/",
        "https://*.amazon.com/*",
        "https://*.amazon.ca/*",
        "https://*.ebay.com/*",
        "https://*.ebay.ca/*",
        "https://www.aliexpress.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.facebook.com/*"
            ],
            "js": [
                "injector_facebook.js"
            ]
        },
        {
            "matches": [
                "https://www.aliexpress.com/*"
            ],
            "js": [
                "injector_aliexpress.js"
            ]
        },
        {
            "matches": [
                "https://my-website-l1fe.vercel.app/admin/dashboard/product-reviews/*"
            ],
            "js": [
                "injector_reviews.js"
            ]
        },
        {
            "matches": [
                "https://www.kijiji.ca/*"
            ],
            "js": [
                "injector_kijiji.js"
            ]
        },
        {
            "matches": [
                "https://my-website-l1fe.vercel.app/admin/dashboard/edit-product/*"
            ],
            "js": [
                "harvester.js"
            ]
        },
        {
            "matches": [
                "https://sellercentral.amazon.ca/*"
            ],
            "js": [
                "injector_amazon.js"
            ]
        },
        {
            "matches": [
                "https://*.ebay.com/*",
                "https://*.ebay.ca/*"
            ],
            "js": [
                "injector_ebay.js"
            ]
        }
    ],
    "action": {
        "default_popup": "src/popup/popup.html"
    }
}